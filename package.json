{
  "name": "valt",
  "displayName": "Valt",
  "description": "A lightweight personal knowledge base for VSCode — markdown files, beautifully rendered.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "valt.open",
        "title": "Valt: Open Knowledge Base"
      },
      {
        "command": "valt.openFile",
        "title": "Valt: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "valt.refreshTree",
        "title": "Valt: Refresh File Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "valt.setTagColor",
        "title": "Set Tag Color"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "valt-sidebar",
          "title": "Valt",
          "icon": "assets/valt-icon.svg"
        }
      ]
    },
    "views": {
      "valt-sidebar": [
        {
          "id": "valt.fileTree",
          "name": "Files"
        },
        {
          "id": "valt.tagTree",
          "name": "Tags"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "valt.refreshTree",
          "when": "view == valt.fileTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "valt.setTagColor",
          "when": "view == valt.tagTree && viewItem == tag",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Valt",
      "properties": {
        "valt.tagColors": {
          "type": "object",
          "description": "Custom hex colors for @tag decorators, keyed by tag name.",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "chrono-node": "^2.9.0",
    "codemirror": "^6.0.2"
  }
}
