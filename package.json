{
  "name": "valt",
  "displayName": "Valt",
  "repository": {
    "type": "git",
    "url": "https://github.com/nshelton/valt"
  },
  "description": "A lightweight personal knowledge base for VSCode — markdown files, beautifully rendered.",
  "version": "1.3.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "valt.open",
        "title": "Valt: Open Knowledge Base"
      },
      {
        "command": "valt.openFile",
        "title": "Valt: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "valt.showHome",
        "title": "Valt: Show Home",
        "icon": "$(home)"
      },
      {
        "command": "valt.refreshTree",
        "title": "Valt: Refresh File Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "valt.setTagColor",
        "title": "Set Tag Color"
      },
      {
        "command": "valt.newSubPage",
        "title": "Add Sub-page"
      },
      {
        "command": "valt.removeFromFavorites",
        "title": "Remove from Favorites"
      },
      {
        "command": "valt.deletePage",
        "title": "Delete Page",
        "icon": "$(trash)"
      },
      {
        "command": "valt.deleteDatabase",
        "title": "Delete Database",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "valt-sidebar",
          "title": "Valt",
          "icon": "assets/valt-icon.svg"
        }
      ]
    },
    "views": {
      "valt-sidebar": [
        {
          "id": "valt.favoritesTree",
          "name": "Favorites"
        },
        {
          "id": "valt.fileTree",
          "name": "Files"
        },
        {
          "id": "valt.tagTree",
          "name": "Tags"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "valt.showHome",
          "when": "view == valt.fileTree",
          "group": "navigation"
        },
        {
          "command": "valt.refreshTree",
          "when": "view == valt.fileTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "valt.setTagColor",
          "when": "view == valt.tagTree && viewItem == tag",
          "group": "inline"
        },
        {
          "command": "valt.newSubPage",
          "when": "view == valt.fileTree && viewItem == valtPage",
          "group": "1_create@1"
        },
        {
          "command": "valt.deletePage",
          "when": "view == valt.fileTree && viewItem == valtPage",
          "group": "inline"
        },
        {
          "command": "valt.deleteDatabase",
          "when": "view == valt.fileTree && viewItem == valtDatabase",
          "group": "inline"
        },
        {
          "command": "valt.removeFromFavorites",
          "when": "view == valt.favoritesTree && viewItem == valtFavorite",
          "group": "1_manage@1"
        }
      ]
    },
    "configuration": {
      "title": "Valt",
      "properties": {
        "valt.tagColors": {
          "type": "object",
          "description": "Custom hex colors for @tag decorators, keyed by tag name.",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@emoji-mart/data": "^1.2.1",
    "chrono-node": "^2.9.0",
    "codemirror": "^6.0.2",
    "emoji-mart": "^5.6.0"
  }
}