{
  "name": "valt",
  "displayName": "Valt",
  "description": "A lightweight personal knowledge base for VSCode — markdown files, beautifully rendered.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "valt.open",
        "title": "Valt: Open Knowledge Base"
      },
      {
        "command": "valt.openFile",
        "title": "Valt: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "valt.refreshTree",
        "title": "Valt: Refresh File Tree",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "valt-sidebar",
          "title": "Valt",
          "icon": "assets/valt-icon.svg"
        }
      ]
    },
    "views": {
      "valt-sidebar": [
        {
          "id": "valt.fileTree",
          "name": "Files"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "valt.refreshTree",
          "when": "view == valt.fileTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "highlight.js": "^11.9.0"
  }
}
